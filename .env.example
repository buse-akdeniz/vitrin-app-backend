NODE_ENV=development
PORT=3000

# Güçlü, rastgele bir değer kullanın.
JWT_SECRET=replace_with_strong_secret

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Opsiyonel: SQLite ve uploads için custom yollar
DB_PATH=./data/dolap.db
UPLOADS_DIR=./uploads

# Opsiyonel: CORS whitelist (virgülle ayırın)
ALLOWED_ORIGINS=http://localhost:3000,http://10.0.2.2:3000
