PORT=3000
AWS_REGION=eu-central-1
S3_RAW_BUCKET=vitrin-images-raw
CDN_BASE_URL=https://cdn.example.com
PRESIGN_EXPIRES_SECONDS=300
MAX_FILE_SIZE_BYTES=15728640
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX=30
CORS_ORIGINS=

# Optional auth for upload endpoints
UPLOAD_API_TOKEN=

# Optional: verify object exists in S3 before complete response
VERIFY_OBJECT_ON_COMPLETE=true

# AI (Support / Stylist)
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_TIMEOUT_MS=20000

# Local JSON datastore (dev)
AUTH_SALT=vitrin-dev-salt-change-me
DATA_DIR=

# Chat WebSocket (same port): ws://HOST:PORT/ws/chat
