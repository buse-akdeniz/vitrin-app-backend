# Railway production env (copy values into Railway Variables)
PORT=3000
AWS_REGION=eu-central-1
S3_RAW_BUCKET=vitrin-original-photos-707605821946-eu-central-1-an
CDN_BASE_URL=https://d130hg8g3tdei3.cloudfront.net
PRESIGN_EXPIRES_SECONDS=300
MAX_FILE_SIZE_BYTES=15728640
UPLOAD_RATE_LIMIT_WINDOW_MS=60000
UPLOAD_RATE_LIMIT_MAX=30
UPLOAD_API_TOKEN=REPLACE_WITH_LONG_RANDOM_SECRET
VERIFY_OBJECT_ON_COMPLETE=true

# Marketplace JSON store — mount a Railway Volume at /app/backend/data
DATA_DIR=/app/backend/data
AUTH_SALT=REPLACE_WITH_LONG_RANDOM_SECRET

# Optional CORS (mobile app does not need this; web clients do)
CORS_ORIGINS=

# AI chat (optional)
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_TIMEOUT_MS=20000
